{
  "info": {
    "name": "EscrowFlow API",
    "_postman_id": "escrowflow-api-collection",
    "description": "Complete API collection for EscrowFlow SaaS Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "projectId", "value": "" },
    { "key": "disputeId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Client",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Abdul Client\",\n  \"email\": \"client@test.com\",\n  \"password\": \"123456\",\n  \"role\": \"client\"\n}"
            }
          }
        },
        {
          "name": "Register Freelancer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ali Freelancer\",\n  \"email\": \"freelancer@test.com\",\n  \"password\": \"123456\",\n  \"role\": \"freelancer\"\n}"
            }
          }
        },
        {
          "name": "Login Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set('token', jsonData.data.token);",
                  "    console.log('Token saved automatically!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@test.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login Freelancer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set('token', jsonData.data.token);",
                  "    console.log('Token saved automatically!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"freelancer@test.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/profile", "host": ["{{baseUrl}}"], "path": ["auth", "profile"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Abdul Updated\",\n  \"bio\": \"Full Stack Developer\"\n}"
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/users", "host": ["{{baseUrl}}"], "path": ["auth", "users"] }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project (Client)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.project && jsonData.data.project._id) {",
                  "    pm.collectionVariables.set('projectId', jsonData.data.project._id);",
                  "    console.log('Project ID saved: ' + jsonData.data.project._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Build React Dashboard\",\n  \"description\": \"Need a premium SaaS dashboard with charts and analytics\",\n  \"budget\": 5000,\n  \"deadline\": \"2026-12-31T00:00:00.000Z\",\n  \"milestones\": [\n    { \"title\": \"Design Phase\", \"amount\": 1500 },\n    { \"title\": \"Development\", \"amount\": 3500 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] }
          }
        },
        {
          "name": "Browse Projects (Freelancer)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/projects/browse", "host": ["{{baseUrl}}"], "path": ["projects", "browse"] }
          }
        },
        {
          "name": "Get Project By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectId}}"] }
          }
        },
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/projects/stats", "host": ["{{baseUrl}}"], "path": ["projects", "stats"] }
          }
        },
        {
          "name": "Assign Freelancer",
          "request": {
            "method": "PUT",
            "header": [],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}/assign", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectId}}", "assign"] }
          }
        },
        {
          "name": "Submit Work (Freelancer)",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}/submit", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectId}}", "submit"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "notes", "value": "Design phase completed successfully", "type": "text" },
                { "key": "files", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Review Submission (Client)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}/review", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectId}}", "review"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"submissionId\": \"PASTE_SUBMISSION_ID_HERE\",\n  \"status\": \"approved\",\n  \"feedback\": \"Great work!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Get All Payments",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/payments", "host": ["{{baseUrl}}"], "path": ["payments"] }
          }
        },
        {
          "name": "Get Project Payments",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/payments/project/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["payments", "project", "{{projectId}}"] }
          }
        },
        {
          "name": "Deposit Funds (Client)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/payments/deposit", "host": ["{{baseUrl}}"], "path": ["payments", "deposit"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectId\": \"{{projectId}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Disputes",
      "item": [
        {
          "name": "Get All Disputes",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/disputes", "host": ["{{baseUrl}}"], "path": ["disputes"] }
          }
        },
        {
          "name": "Raise Dispute",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/disputes", "host": ["{{baseUrl}}"], "path": ["disputes"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "projectId", "value": "{{projectId}}", "type": "text" },
                { "key": "reason", "value": "Deadline missed by freelancer", "type": "text" },
                { "key": "evidence", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Resolve Dispute (Admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/disputes/{{disputeId}}/resolve", "host": ["{{baseUrl}}"], "path": ["disputes", "{{disputeId}}", "resolve"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resolution\": \"Refund to client\",\n  \"winnerId\": \"PASTE_USER_ID_HERE\"\n}"
            }
          }
        }
      ]
    }
  ]
}
